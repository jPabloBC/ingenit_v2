{
	"$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
	"files": {
		"includes": [
			"**",
			"!.next",
			"!node_modules",
			"!dist",
			"!build",
			"!coverage"
		]
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"rules": {
			"suspicious": {
				"noUnknownAtRules": "off"
			}
		}
	}
}
